<!-- app/src/views/index.ejs -->
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>BOO Exercise - Todo App</title>
<style>
body { font-family: Arial; max-width: 600px; margin: 50px auto; padding: 20px; }
h1 { color: #2E75B6; }
.todo-form { display: flex; gap: 10px; margin-bottom: 20px; }
.todo-form input { flex: 1; padding: 10px; border: 1px solid #ccc; border-radius:
4px; }
.todo-form button { padding: 10px 20px; background: #2E75B6; color: white; border:
none; border-radius: 4px; cursor: pointer; }
.todo-item { display: flex; align-items: center; gap: 10px; padding: 10px; border-
bottom: 1px solid #eee; }
.completed { text-decoration: line-through; color: #999; }
.badge { background: #4CAF50; color: white; padding: 2px 8px; border-radius: 12px;
font-size: 12px; }
</style>
</head>
<body>
<h1>BOO Security Exercise - WIZ CNAPP</h1>
<p class="badge">MongoDB 연결됨</p>
<form action="/todos" method="POST" class="todo-form">
<input type="text" name="title" placeholder="새 할일 입력..." required>
<button type="submit">추가</button>
</form>
<% todos.forEach(todo => { %>
<div class="todo-item">
<form action="/todos/<%= todo._id %>/toggle" method="POST">
<input type="checkbox" onchange="this.form.submit()" <%= todo.completed ?
"checked" : "" %>>
</form>
<span class="<%= todo.completed ? 'completed' : '' %>"><%= todo.title %></span>
<small style="color:#999; margin-left:auto">
<%= todo.createdAt.toLocaleDateString() %>
</small>
</div>
<% }) %>
</body>
</html>
